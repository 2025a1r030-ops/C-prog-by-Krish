#include <stdio.h>  
#define MAX 100  
#include <stdlib.h>

struct queue{ 
    int data; 
    int priority; 
}; 

struct queue pqueue[MAX]; 
int front = -1, rear = -1; 

int isempty(){ 
    return front == -1;
} 

int isfull(){ 
    return rear == MAX-1;
} 

void enqueue(int data, int priority){ 
    if(isfull()){ 
        printf("Queue Overflow\n"); 
        return;
    } 
    rear++; 
    pqueue[rear].data = data; 
    pqueue[rear].priority = priority; 

    if(front == -1) 
        front = rear; 

    printf("Element inserted in priority queue\n");
} 

int getHighpriority(){ 
    int max = pqueue[front].priority, index = front;

    for(int i=front; i<=rear; i++){ 
        if(pqueue[i].priority > max){
            max = pqueue[i].priority;  
            index = i;
        } 
    } 
    return index;
} 

int dequeue(){ 
    if(isempty()){ 
        printf("Queue Underflow\n"); 
        return -1;
    } 

    int index = getHighpriority(); 
    int val = pqueue[index].data;

    for(int i=index; i<rear; i++){ 
        pqueue[i] = pqueue[i+1];
    }  

    rear--; 

    if(rear < front) 
        front = rear = -1;

    return val;
}

int peek(){ 
    if(isempty()){ 
        printf("Queue Underflow\n"); 
        return -1;
    } 

    int index = getHighpriority(); 
    return pqueue[index].data;
} 

void display(){ 
    if(isempty()){ 
        printf("Queue is empty!!!\n"); 
        return;
    } 

    for(int i=front; i<=rear; i++){ 
        printf("%d --> %d\n", pqueue[i].priority, pqueue[i].data);
    }
}  

int main(){ 
    int choice, value, priority; 

    while(1){
        printf("1.Enqueue\n");
        printf("2.Dequeue\n"); 
        printf("3.Peek\n"); 
        printf("4.Display\n"); 
        printf("5. Exit\n");
        printf("Enter choice: ");
        scanf("%d",&choice);

        switch(choice){ 

            case 1: 
                printf("Enter Value: "); 
                scanf("%d", &value); 
                printf("Enter Priority: "); 
                scanf("%d", &priority); 
                enqueue(value, priority); 
                break;  

            case 2:  
                value = dequeue(); 
                if(value != -1)
                    printf("Deleted element: %d\n", value);
                break;

            case 3:
                value = peek();
                if(value != -1)
                    printf("Highest Priority element: %d\n", value);
                break;

            case 4:
                display();
                break;

            case 5: 
            exit(0);
                return 0;

            default:
                printf("Invalid\n");
        }
    }
}
